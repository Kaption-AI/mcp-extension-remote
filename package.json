{
  "name": "@kaptionai/mcp-remote",
  "version": "1.0.0",
  "private": true,
  "description": "Cloud MCP relay for WhatsApp — Cloudflare Worker with WhatsApp OTP auth",
  "module": "./src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
