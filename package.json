    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.30",
    "@cloudflare/workers-types": "^4.20250405.0",
    "@types/node": "^24.0.3",
    "typescript": "^5.6.3",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
