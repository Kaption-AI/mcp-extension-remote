{
  "name": "@kaptionai/mcp-remote",
  "version": "1.0.0",
  "private": true,
  "license": "BUSL-1.1",
  "description": "Cloud MCP relay for WhatsApp — Cloudflare Worker with WhatsApp OTP auth",
  "module": "./src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:worker": "npx @opennextjs/cloudflare build && node scripts/wrap-worker.mjs",
    "deploy": "test \"$CI\" = 'true' || (echo '❌ Deploy blocked: must run through GitHub Actions CI pipeline (Sigstore signing required)' && exit 1) && npm run build:worker && npx wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.0.12",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "agents": "^0.7.6",
    "ai": "^6.0.116",
    "hono": "^4.4.0",
    "jose": "^6.2.1",
    "next": "~15.2.9",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.30",
    "@cloudflare/workers-types": "^4.20250405.0",
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/node": "^24.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "postcss": "^8",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
